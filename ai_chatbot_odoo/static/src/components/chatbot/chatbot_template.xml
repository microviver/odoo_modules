<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
  <t t-name="ai_chatbot_odoo.ChatbotTemplate" owl="1">
    <div class="chatbot-box">
      <div class="chatbot-header">Simbi 🤖</div>
      <div class="chatbot-messages">
        <t t-foreach="messages" t-as="msg">
          <div t-att-class="msg.type === 'user' ? 'user-msg' : 'bot-msg'">
            <t t-esc="msg.text"/>
          </div>
        </t>
        <div t-if="loading" class="chatbot-typing"><em>piensando...</em></div>
      </div>
      <input type="text" class="chatbot-input"
             t-model="inputValue"
             t-on-keydown.enter.prevent="sendMessage"/>
    </div>
  </t>
</templates>
